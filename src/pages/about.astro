---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site";
import { about } from "../config/about";

const bioParagraphs = about.bio.split(/\n\s*\n/);
---

<BaseLayout title="About">
  <!-- ═══════════════════════════════════════════════════════════════════
       ABOUT HERO
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="about-hero">
    <div class="container about-hero-inner">
      <div class="about-photo" aria-hidden="true">
        <img src={about.photo} alt={about.photoAlt} onerror="this.style.opacity=0" />
        <div class="photo-frame"></div>
      </div>
      <div class="about-intro">
        <div class="eyebrow">About</div>
        <h1>{site.name}</h1>
        <div class="muted about-tag">{site.tagline} · {site.location}</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       BIO
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="bio">
    <div class="container-narrow">
      {bioParagraphs.map((p) => <p class="bio-p">{p}</p>)}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       EDUCATION
       ═══════════════════════════════════════════════════════════════════ -->
  <section>
    <div class="container-narrow">
      <div class="eyebrow">Education</div>
      <h2>Background</h2>
      <hr class="rule" />
      <div class="entries">
        {about.education.map((e) => (
          <article class="entry">
            <header class="entry-head">
              <h3 class="entry-title">{e.institution}</h3>
              <span class="entry-date mono">{e.date}</span>
            </header>
            <div class="muted entry-sub">{e.degree} · {e.location}</div>
            {e.details && <p class="entry-body">{e.details}</p>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       PUBLICATIONS
       ═══════════════════════════════════════════════════════════════════ -->
  {about.publications.length > 0 && (
    <section>
      <div class="container-narrow">
        <div class="eyebrow">Publications & Presentations</div>
        <h2>Research Output</h2>
        <hr class="rule" />
        <ol class="pubs">
          {about.publications.map((pub) => (
            <li class="pub">
              <div class="pub-title">
                {pub.link ? <a href={pub.link} target="_blank" rel="noopener" class="link">{pub.title}</a> : pub.title}
              </div>
              <div class="muted pub-authors">{pub.authors}</div>
              <div class="pub-meta mono">{pub.venue} · {pub.date}</div>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════════════
       SKILLS
       ═══════════════════════════════════════════════════════════════════ -->
  <section>
    <div class="container-narrow">
      <div class="eyebrow">Toolkit</div>
      <h2>Skills</h2>
      <hr class="rule" />
      <div class="skills">
        {about.skills.map((group) => (
          <div class="skill-group">
            <h3 class="skill-heading">{group.group}</h3>
            <ul class="tags">
              {group.items.map((item) => <li class="tag">{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       CONTACT STRIP
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="contact-strip">
    <div class="container-narrow center">
      <div class="eyebrow">Get In Touch</div>
      <h2>Let's build something.</h2>
      <p class="muted">
        Best way to reach me is email. I try to respond within a day or two.
      </p>
      <a href={`mailto:${site.email}`} class="btn btn-primary">{site.email}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero { padding-top: 5rem; padding-bottom: 2rem; }
  .about-hero-inner {
    display: flex;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .about-photo {
    position: relative;
    width: 200px;
    aspect-ratio: 3 / 4;
    flex-shrink: 0;
  }
  .about-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.85);
  }
  .photo-frame {
    position: absolute;
    inset: 0;
    border: 1px solid var(--color-border-bright);
    background:
      linear-gradient(135deg,
        color-mix(in oklab, var(--color-ocean) 35%, transparent),
        color-mix(in oklab, var(--color-forest) 20%, transparent));
    mix-blend-mode: multiply;
  }
  .about-photo::before {
    content: "";
    position: absolute;
    inset: 10px -10px -10px 10px;
    border: 1px solid var(--color-forest);
    z-index: -1;
    opacity: 0.5;
  }
  .about-intro h1 { margin-bottom: 0.25rem; }
  .about-tag { font-size: 1rem; }

  .bio { padding-top: 2rem; padding-bottom: 4rem; }
  .bio-p {
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--color-text);
  }
  .bio-p:first-of-type::first-letter {
    font-family: var(--font-display);
    font-size: 3.2rem;
    float: left;
    line-height: 0.9;
    padding: 0.4rem 0.6rem 0 0;
    color: var(--color-forest-bright);
  }

  /* Entries (education) */
  .entries { display: flex; flex-direction: column; gap: 2rem; }
  .entry {
    border-left: 2px solid var(--color-border-bright);
    padding-left: 1.5rem;
  }
  .entry-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .entry-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
  }
  .entry-date {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--color-forest-bright);
  }
  .entry-sub { margin: 0.3rem 0 0.6rem; font-size: 0.95rem; }
  .entry-body { color: var(--color-text-muted); }

  /* Publications */
  .pubs {
    list-style: decimal;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .pubs::marker { color: var(--color-forest-bright); }
  .pub-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }
  .pub-authors { font-size: 0.9rem; font-style: italic; }
  .pub-meta {
    font-size: 0.75rem;
    color: var(--color-text-faint);
    letter-spacing: 0.05em;
    margin-top: 0.3rem;
  }

  /* Skills */
  .skills { display: flex; flex-direction: column; gap: 2rem; }
  .skill-group { display: flex; flex-direction: column; gap: 0.8rem; }
  .skill-heading {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-forest-bright);
  }

  /* Contact strip */
  .contact-strip {
    border-top: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-bg-subtle) 70%, transparent);
    margin-top: 3rem;
  }
  .contact-strip h2 { margin-bottom: 0.75rem; }
  .contact-strip p { margin-bottom: 1.5rem; }
</style>
