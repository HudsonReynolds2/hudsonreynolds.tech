---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../config/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

// Render a section body with paragraph breaks preserved.
function paragraphs(text: string): string[] {
  return text.split(/\n\s*\n/).filter(Boolean);
}
---

<BaseLayout title={project.title} description={project.summary}>
  <article class="project">
    <!-- ═════════════════════════════════════════════════════════════════
         HERO IMAGE
         ═════════════════════════════════════════════════════════════════ -->
    <div class="project-hero-image" aria-hidden="true">
      <img src={project.image} alt={project.title} onerror="this.style.opacity=0" />
      <div class="project-hero-overlay"></div>
    </div>

    <!-- ═════════════════════════════════════════════════════════════════
         TITLE BLOCK
         ═════════════════════════════════════════════════════════════════ -->
    <header class="project-head">
      <div class="container-narrow">
        <a href="/projects" class="back">← All projects</a>
        {project.year && <div class="eyebrow">{project.year}{project.role ? ` · ${project.role}` : ""}</div>}
        <h1>{project.title}</h1>
        {project.subtitle && <p class="project-sub">{project.subtitle}</p>}
        <p class="project-summary">{project.summary}</p>

        <ul class="tags project-tags">
          {project.tags.map((t) => <li class="tag">{t}</li>)}
        </ul>

        {project.links && project.links.length > 0 && (
          <div class="project-links">
            {project.links.map((link) => (
              <a href={link.href} target="_blank" rel="noopener" class="btn">
                {link.label} ↗
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- ═════════════════════════════════════════════════════════════════
         LONG-FORM SECTIONS
         ═════════════════════════════════════════════════════════════════ -->
    {project.sections && project.sections.length > 0 ? (
      <div class="project-body">
        <div class="container-narrow">
          {project.sections.map((section) => (
            <section class="project-section">
              <h2>{section.heading}</h2>
              {paragraphs(section.body).map((p) => <p>{p}</p>)}
            </section>
          ))}
        </div>
      </div>
    ) : (
      <div class="project-body">
        <div class="container-narrow">
          <section class="project-section">
            <p class="muted">
              A full writeup for this project is coming soon. For now, see the
              links above for source code and details.
            </p>
          </section>
        </div>
      </div>
    )}

    <!-- ═════════════════════════════════════════════════════════════════
         GALLERY  (clickable → lightbox)
         ═════════════════════════════════════════════════════════════════ -->
    {project.gallery && project.gallery.length > 0 && (
      <section class="project-gallery">
        <div class="container">
          <div class="eyebrow">Gallery</div>
          <h2>Images</h2>
          <hr class="rule" />
          <div class="gallery-grid" id="gallery-grid">
            {project.gallery.map((img, i) => (
              <button
                type="button"
                class="gallery-item"
                data-lightbox-index={i}
                data-lightbox-src={img}
                aria-label={`Open image ${i + 1} of ${project.gallery!.length}`}
              >
                <img src={img} alt="" loading="lazy" onerror="this.closest('.gallery-item').style.display='none'" />
                <span class="gallery-zoom" aria-hidden="true">⤢</span>
              </button>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═════════════════════════════════════════════════════════════════
         LIGHTBOX OVERLAY (hidden by default, controlled by script below)
         ═════════════════════════════════════════════════════════════════ -->
    {project.gallery && project.gallery.length > 0 && (
      <div
        class="lightbox"
        id="lightbox"
        role="dialog"
        aria-modal="true"
        aria-label="Image viewer"
        hidden
      >
        <button type="button" class="lightbox-close" aria-label="Close">✕</button>
        <button type="button" class="lightbox-nav lightbox-prev" aria-label="Previous image">‹</button>
        <button type="button" class="lightbox-nav lightbox-next" aria-label="Next image">›</button>
        <figure class="lightbox-figure">
          <img id="lightbox-img" src="" alt="" />
          <figcaption class="lightbox-counter mono" id="lightbox-counter"></figcaption>
        </figure>
      </div>
    )}

    <!-- ═════════════════════════════════════════════════════════════════
         NEXT STEPS
         ═════════════════════════════════════════════════════════════════ -->
    <section class="project-footer">
      <div class="container-narrow center">
        <a href="/projects" class="btn">← All projects</a>
      </div>
    </section>
  </article>
</BaseLayout>

{project.gallery && project.gallery.length > 0 && (
  <script is:inline define:vars={{ images: project.gallery }}>
    // ─────────────────────────────────────────────────────────────────────
    // Lightbox: open gallery images full-size, navigate with arrows / ESC
    // ─────────────────────────────────────────────────────────────────────
    const lb       = document.getElementById("lightbox");
    const lbImg    = document.getElementById("lightbox-img");
    const lbCount  = document.getElementById("lightbox-counter");
    const btnClose = lb.querySelector(".lightbox-close");
    const btnPrev  = lb.querySelector(".lightbox-prev");
    const btnNext  = lb.querySelector(".lightbox-next");
    let current = 0;

    function show(i) {
      current = (i + images.length) % images.length;
      lbImg.src = images[current];
      lbCount.textContent = `${current + 1} / ${images.length}`;
    }
    function open(i) {
      show(i);
      lb.hidden = false;
      document.body.style.overflow = "hidden";
    }
    function close() {
      lb.hidden = true;
      lbImg.src = "";
      document.body.style.overflow = "";
    }

    document.querySelectorAll("[data-lightbox-index]").forEach((el) => {
      el.addEventListener("click", (e) => {
        e.preventDefault();
        open(Number(el.dataset.lightboxIndex));
      });
    });

    btnClose.addEventListener("click", close);
    btnPrev .addEventListener("click", () => show(current - 1));
    btnNext .addEventListener("click", () => show(current + 1));

    // Click outside the image to close
    lb.addEventListener("click", (e) => {
      if (e.target === lb || e.target.classList.contains("lightbox-figure")) close();
    });

    // Keyboard controls
    document.addEventListener("keydown", (e) => {
      if (lb.hidden) return;
      if (e.key === "Escape")     close();
      if (e.key === "ArrowLeft")  show(current - 1);
      if (e.key === "ArrowRight") show(current + 1);
    });
  </script>
)}

<style>
  /* ─── Hero image ───────────────────────────────────────────────────── */
  .project-hero-image {
    position: relative;
    width: 100%;
    /* Taller min-height so `contain`-fitted images have room to breathe */
    height: clamp(320px, 55vh, 620px);
    overflow: hidden;
    /* Gradient fills the bars around images that aren't 16:9-ish */
    background:
      linear-gradient(135deg,
        color-mix(in oklab, var(--color-ocean-deep) 85%, transparent) 0%,
        color-mix(in oklab, var(--color-forest) 45%, transparent) 100%
      );
    border-bottom: 1px solid var(--color-border);
  }
  .project-hero-image img {
    width: 100%;
    height: 100%;
    /* `contain` so diagrams, screenshots, etc. are never cropped */
    object-fit: contain;
    /* A little padding so the image doesn't butt against the edges */
    padding: 1.5rem;
    filter: saturate(0.95);
  }
  .project-hero-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 70%,
      color-mix(in oklab, var(--color-bg) 85%, transparent) 100%
    );
  }

  /* ─── Title ────────────────────────────────────────────────────────── */
  .project-head { padding-top: 3rem; padding-bottom: 3rem; }
  .back {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-forest-bright);
    margin-bottom: 2rem;
    display: inline-block;
  }
  .back:hover { color: var(--color-text); }
  .project-head h1 {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    margin: 0.5rem 0;
  }
  .project-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }
  .project-summary {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--color-text);
    max-width: 60ch;
    margin-bottom: 1.5rem;
  }
  .project-tags { margin-bottom: 2rem; }
  .project-links { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  /* ─── Body ─────────────────────────────────────────────────────────── */
  .project-body {
    border-top: 1px solid var(--color-border);
    padding: 4rem 0 2rem;
    background: color-mix(in oklab, var(--color-bg-subtle) 40%, transparent);
  }
  .project-section { margin-bottom: 3rem; }
  .project-section h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    margin-bottom: 1rem;
    color: var(--color-forest-bright);
  }
  .project-section p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-text);
    margin-bottom: 1.2rem;
    white-space: pre-line;
  }

  /* ─── Gallery ──────────────────────────────────────────────────────── */
  .project-gallery { padding-top: 3rem; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .gallery-item {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background:
      linear-gradient(135deg,
        color-mix(in oklab, var(--color-ocean-deep) 60%, transparent) 0%,
        color-mix(in oklab, var(--color-forest) 30%, transparent) 100%
      );
    cursor: zoom-in;
    padding: 0;
    display: block;
    /* reset button defaults */
    font: inherit;
    color: inherit;
    text-align: left;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    /* `contain` so gallery thumbnails also show the whole image */
    object-fit: contain;
    transition: transform 0.5s var(--ease);
  }
  .gallery-item:hover img { transform: scale(1.04); }
  /* Little zoom-hint icon, so the "these are clickable" signal is clearer */
  .gallery-zoom {
    position: absolute;
    top: 0.6rem;
    right: 0.7rem;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    font-size: 0.9rem;
    color: var(--color-text);
    background: color-mix(in oklab, var(--color-bg) 70%, transparent);
    border: 1px solid var(--color-border-bright);
    border-radius: 2px;
    opacity: 0;
    transition: opacity 0.2s var(--ease);
    pointer-events: none;
  }
  .gallery-item:hover .gallery-zoom,
  .gallery-item:focus-visible .gallery-zoom { opacity: 1; }
  .gallery-item:focus-visible {
    outline: 2px solid var(--color-forest-bright);
    outline-offset: 2px;
  }

  /* ─── Lightbox ─────────────────────────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    background: color-mix(in oklab, var(--color-bg) 94%, black);
    backdrop-filter: blur(8px);
    animation: lbFadeIn 0.2s var(--ease);
  }
  .lightbox[hidden] { display: none; }

  @keyframes lbFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .lightbox-figure {
    margin: 0;
    padding: 2rem;
    max-width: 95vw;
    max-height: 95vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .lightbox-figure img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    box-shadow: 0 10px 60px rgba(0,0,0,0.6);
  }
  .lightbox-counter {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Close / nav buttons */
  .lightbox-close,
  .lightbox-nav {
    position: absolute;
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    font-size: 1.4rem;
    color: var(--color-text);
    background: color-mix(in oklab, var(--color-bg-elevated) 85%, transparent);
    border: 1px solid var(--color-border-bright);
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s var(--ease);
  }
  .lightbox-close:hover,
  .lightbox-nav:hover {
    background: var(--color-bg-elevated);
    border-color: var(--color-forest-bright);
  }
  .lightbox-close {
    top: 1.25rem;
    right: 1.25rem;
  }
  .lightbox-prev { left: 1.25rem;  top: 50%; transform: translateY(-50%); }
  .lightbox-next { right: 1.25rem; top: 50%; transform: translateY(-50%); }

  @media (max-width: 640px) {
    .lightbox-prev { left: 0.5rem; }
    .lightbox-next { right: 0.5rem; }
    .lightbox-close { top: 0.5rem; right: 0.5rem; }
  }

  .project-footer { padding-top: 3rem; padding-bottom: 1rem; }
</style>
