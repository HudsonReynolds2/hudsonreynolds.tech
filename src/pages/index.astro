---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { site } from "../config/site";
import { featuredProjects } from "../config/projects";
---

<BaseLayout>
  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — full-bleed atmospheric forest
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="hero">
    {site.heroImage.src && (
      <div class="hero-bg" aria-hidden="true">
        <picture>
          <source media="(max-width: 720px)" srcset={site.heroImage.srcMobile} />
          <img src={site.heroImage.src} alt="" style={`object-position: ${site.heroImage.position};`} />
        </picture>
        <div class="hero-bg-overlay" style={`--darken: ${site.heroImage.darken};`}></div>
      </div>
    )}

    <div class="container hero-inner">
      <div class="hero-text">
        <div class="eyebrow reveal d1">Computer Engineer · BU '26</div>
        <h1 class="reveal d2">
          <span class="hero-name">{site.name}</span>
          <span class="hero-verb">builds systems that</span>
          <span class="hero-emphasis">bridge hardware and the cloud.</span>
        </h1>
        <p class="hero-blurb reveal d3">{site.blurb}</p>
        <div class="hero-actions reveal d4">
          <a href="/projects" class="btn btn-primary">View Projects</a>
          <a href="/about" class="btn">About Me</a>
        </div>
      </div>
    </div>

    {site.heroImage.caption && (
      <div class="hero-caption mono" aria-hidden="true">{site.heroImage.caption}</div>
    )}
    <div class="horizon" aria-hidden="true"></div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       FEATURED PROJECTS
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="projects-section">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Selected Work</div>
          <h2>Featured projects</h2>
        </div>
        <a href="/projects" class="all-link">All projects →</a>
      </div>
      <hr class="rule" />

      <div class="project-grid">
        {featuredProjects.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       INLINE CTA / CONTACT STRIP
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="cta">
    <div class="container cta-inner">
      <div>
        <div class="eyebrow">{site.cta.eyebrow}</div>
        <h2>{site.cta.headline}</h2>
        <p class="muted">{site.cta.subtext}</p>
        </div>
      <div class="cta-actions">
        <a href={`mailto:${site.email}`} class="btn btn-primary">{site.email}</a>
        {site.socials.resume && (
          <a href={site.socials.resume} class="btn" target="_blank" rel="noopener">Resume (PDF)</a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- Hero: full-bleed atmospheric ---------- */
  .hero {
    position: relative;
    min-height: clamp(520px, 85vh, 780px);
    padding: 0;
    display: flex;
    align-items: center;
    overflow: hidden;
    /* Pull the hero up through the header — header is translucent, so this
       gives the background image a chance to peek through the nav. */
    margin-top: calc(-1 * (1rem + 2.5rem));
    padding-top: calc(1rem + 2.5rem);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Subtle movement: scale + slow drift feels atmospheric, not cheesy. */
    animation: heroDrift 40s ease-in-out infinite alternate;
    filter: saturate(1.05) contrast(1.03);
  }
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    /* Readability overlay — top is darker for nav contrast, bottom fades
       into the page background for a clean hand-off. */
    background:
      linear-gradient(
        to bottom,
        color-mix(in oklab, var(--color-bg) calc(var(--darken) * 100%), transparent) 0%,
        color-mix(in oklab, var(--color-bg) calc(var(--darken) * 80%), transparent) 40%,
        color-mix(in oklab, var(--color-bg) calc(var(--darken) * 110%), transparent) 85%,
        var(--color-bg) 100%
      ),
      /* Subtle ocean tint layered over the forest to keep palette cohesion */
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--color-ocean-deep) 25%, transparent) 0%,
        transparent 60%
      );
  }

  @keyframes heroDrift {
    from { transform: scale(1.04) translate3d(0, 0, 0); }
    to   { transform: scale(1.08) translate3d(-1.5%, -1%, 0); }
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
  }
  .hero-text { max-width: 720px; }
  .hero h1 {
    font-size: clamp(2.6rem, 6vw, 4.6rem);
    line-height: 1.05;
    margin-bottom: 1.5rem;
    /* Drop shadow helps text stand off the photo */
    text-shadow: 0 2px 24px color-mix(in oklab, var(--color-bg) 60%, transparent);
  }
  .hero-name {
    display: block;
    font-weight: 400;
    color: var(--color-text);
  }
  .hero-verb {
    display: block;
    color: color-mix(in oklab, var(--color-text) 85%, transparent);
    font-style: italic;
    font-weight: 300;
  }
  .hero-emphasis {
    display: block;
    color: var(--color-forest-bright);
    font-weight: 400;
  }
  .hero-blurb {
    font-size: 1.1rem;
    color: color-mix(in oklab, var(--color-text) 82%, transparent);
    max-width: 58ch;
    margin-bottom: 2rem;
    text-shadow: 0 1px 12px color-mix(in oklab, var(--color-bg) 70%, transparent);
  }
  .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  /* Small photo-credit in the corner, like a print photograph */
  .hero-caption {
    position: absolute;
    right: 1.5rem;
    bottom: 1.25rem;
    z-index: 2;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-text) 55%, transparent);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    padding-right: 0.25rem;
    border-right: 1px solid color-mix(in oklab, var(--color-text) 25%, transparent);
  }
  @media (max-width: 720px) {
    .hero-caption {
      writing-mode: horizontal-tb;
      transform: none;
      border-right: none;
      border-top: 1px solid color-mix(in oklab, var(--color-text) 25%, transparent);
      padding: 0.25rem 0 0;
      right: 1.5rem;
      bottom: 1rem;
    }
  }

  .horizon {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    z-index: 3;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border-bright) 30%,
      var(--color-border-bright) 70%,
      transparent
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg img { animation: none; transform: scale(1.02); }
  }

  /* ---------- Section heads ---------- */
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .all-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-forest-bright);
    padding-bottom: 0.4rem;
  }
  .all-link:hover { color: var(--color-text); }

  /* ---------- Project grid ---------- */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  /* ---------- CTA ---------- */
  .cta {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-bg-subtle) 70%, transparent);
    margin-top: 3rem;
  }
  .cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .cta h2 { font-size: clamp(1.4rem, 2.4vw, 1.9rem); max-width: 40ch; }
  .cta-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
</style>
