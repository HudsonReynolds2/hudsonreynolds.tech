---
import "../styles/global.css";
import { site } from "../config/site";

type Props = {
  title?: string;
  description?: string;
};

const { title, description } = Astro.props;
const fullTitle = title ? `${title} · ${site.name}` : `${site.name} — ${site.tagline}`;
const desc = description ?? site.blurb;
const t = site.theme;

// Build the :root override so the palette in site.ts is the source of truth.
const themeCSS = `
  :root {
    --color-bg: ${t.bg};
    --color-bg-elevated: ${t.bgElevated};
    --color-bg-subtle: ${t.bgSubtle};
    --color-text: ${t.text};
    --color-text-muted: ${t.textMuted};
    --color-text-faint: ${t.textFaint};
    --color-ocean: ${t.ocean};
    --color-ocean-deep: ${t.oceanDeep};
    --color-forest: ${t.forest};
    --color-forest-bright: ${t.forestBright};
    --color-sand: ${t.sand};
    --color-border: ${t.border};
    --color-border-bright: ${t.borderBright};
  }
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{fullTitle}</title>

    <!-- Fonts: Fraunces (display serif), Hanken Grotesk (body), JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Hanken+Grotesk:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style set:html={themeCSS}></style>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">
          <span class="brand-name">{site.name}</span>
          <span class="brand-tag mono">{site.tagline}</span>
        </a>
        <nav class="nav" aria-label="Main">
          <ul>
            {site.nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  target={(item as any).external ? "_blank" : undefined}
                  rel={(item as any).external ? "noopener" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-left">
          <div class="footer-name">{site.name}</div>
          <div class="muted">{site.tagline} · {site.location}</div>
        </div>
        <div class="footer-right">
          <a href={`mailto:${site.email}`} class="link">{site.email}</a>
          <div class="footer-socials">
            {site.socials.github    && <a href={site.socials.github}    target="_blank" rel="noopener" aria-label="GitHub">GitHub</a>}
            {site.socials.linkedin  && <a href={site.socials.linkedin}  target="_blank" rel="noopener" aria-label="LinkedIn">LinkedIn</a>}
            {site.socials.scholar   && <a href={site.socials.scholar}   target="_blank" rel="noopener" aria-label="Google Scholar">Scholar</a>}
            {site.socials.resume    && <a href={site.socials.resume}    target="_blank" rel="noopener" aria-label="Resume">Resume</a>}
          </div>
        </div>
      </div>
      <div class="container footer-bottom muted">
        <span>© {new Date().getFullYear()} {site.name}</span>
        <span class="faint mono">built with astro · hosted on cloudflare</span>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(14px);
        background: color-mix(in oklab, var(--color-bg) 70%, transparent);
        border-bottom: 1px solid var(--color-border);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1rem;
        padding-bottom: 1rem;
      }
      .brand {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }
      .brand-name {
        font-family: var(--font-display);
        font-size: 1.4rem;
        font-weight: 400;
        letter-spacing: -0.01em;
      }
      .brand-tag {
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        color: var(--color-text-muted);
        text-transform: uppercase;
        margin-top: 2px;
      }
      .nav ul {
        display: flex;
        gap: 2rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .nav a {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--color-text-muted);
        position: relative;
        padding: 0.25rem 0;
        transition: color 0.2s var(--ease);
      }
      .nav a::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -2px;
        height: 1px;
        background: var(--color-forest-bright);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s var(--ease);
      }
      .nav a:hover { color: var(--color-text); }
      .nav a:hover::after { transform: scaleX(1); }

      @media (max-width: 640px) {
        .brand-tag { display: none; }
        .nav ul { gap: 1.25rem; }
      }

      /* Footer */
      .site-footer {
        border-top: 1px solid var(--color-border);
        margin-top: 6rem;
        padding: 3rem 0 2rem;
        background: color-mix(in oklab, var(--color-bg-subtle) 50%, transparent);
      }
      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: 2rem;
      }
      .footer-name {
        font-family: var(--font-display);
        font-size: 1.5rem;
      }
      .footer-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.5rem;
      }
      .footer-socials {
        display: flex;
        gap: 1rem;
      }
      .footer-socials a {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-text-muted);
        transition: color 0.2s var(--ease);
      }
      .footer-socials a:hover { color: var(--color-forest-bright); }
      .footer-bottom {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 0.5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
        font-size: 0.85rem;
      }
      @media (max-width: 640px) {
        .footer-right { align-items: flex-start; }
      }
    </style>
  </body>
</html>
